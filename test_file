  # Useful Postman test sequence                         
                                                         
  ## A. Registry                                         
                                                         
  1. GET /api/excel/template/registry                    
                                                         
  ## B. Download template                                
                                                         
  2. GET /api/excel/template?type=student                
                                                         
  ## C. Upload                                           
                                                         
  3. POST /api/excel/upload                              
                                                         
  - form-data:                                           
      - file                                             
      - uploadType=student                               
                                                         
  ## D. Poll job                                         
                                                         
  4. GET /api/excel/jobs/:jobId                          
                                                         
  Repeat until:                                          
                                                         
  - status = completed or failed                         
  - progress = 100
                                                         
  ## E. If failed rows exist                             
                                                         
  5. GET /api/excel/jobs/:jobId/error-file
                                                         
