  ## 3. Generate custom template                         
                                                         
  POST /api/excel/template/custom                        
                                                         
  Headers                                                
                                                         
  - x-admin-api-key                                      
  - x-user-id                                            
  - Content-Type: application/json                       
                                                         
  Body                                                   
                                                         
  {                                                      
    "templateName": "Custom Upload",                     
    "uploadType": "placement",                           
    "fields": [                                          
      { "table": "students", "field": "name" },          
      { "table": "students", "field": "email" },         
      { "table": "students", "field": "department" },    
      { "table": "placements", "field": "company" }      
    ]                                                    
  }                                                      
                                                         
  Success response                                       
                                                         
  - Binary .xlsx download                                
                                                         
  Important rules                                        
                                                         
  - No duplicate fields                                  
  - Required fields for that uploadType must be included 
  - Unknown fields are rejected                          
                                                         
  Possible 400 errors                                    
                                                         
  { "error": "Invalid template field                     
  \"students.phone\"" }                                  
                                                         
  { "error": "Duplicate template field                   
  \"students.email\"" }                                  
                                                         
  { "error": "Template is missing required field(s):     
  students.email, students.department" }                 
                                                         
