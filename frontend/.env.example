# Public API base URL — used by the browser to hit the notification backend
# In Docker: set via VITE_API_URL build arg
VITE_API_URL=http://localhost:4400

# Internal URL used to proxy /api/tables, /api/import/*, etc. to the db-importer service
# Dev: used by vite.config.js server.proxy
# Production: used by nginx.conf (set as env var in the container)
DB_IMPORTER_URL=http://localhost:3001
