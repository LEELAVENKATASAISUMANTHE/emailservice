# Public API base URL — used by browser-side pages to hit the backend
# In Docker: set via VITE_API_URL build arg and runtime env
VITE_API_URL=http://localhost:4400

# Internal URL the Next.js server uses to proxy /api/tables, /api/import/*, etc.
# In Docker: should resolve to the backend container (e.g. http://emailservice-backend:4000)
DB_IMPORTER_URL=http://localhost:4000
