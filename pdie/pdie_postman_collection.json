{
  "info": {
    "name": "PDIE Backend API",
    "description": "Placement Data Ingestion Engine — Full API collection.\n\nBase URL defaults to http://134.209.159.132:5400",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://134.209.159.132:5400"
    },
    {
      "key": "TEMPLATE_ID",
      "value": ""
    },
    {
      "key": "UPLOAD_ID",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/health", "host": ["{{BASE_URL}}"], "path": ["health"] }
          }
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/health/ready", "host": ["{{BASE_URL}}"], "path": ["health", "ready"] },
            "description": "Checks MongoDB, PostgreSQL, and MinIO connectivity. Returns 503 if any dependency is down."
          }
        }
      ]
    },
    {
      "name": "Tables",
      "item": [
        {
          "name": "List All Tables",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/tables", "host": ["{{BASE_URL}}"], "path": ["api", "tables"] },
            "description": "Returns all tables in the PostgreSQL schema with column counts."
          }
        },
        {
          "name": "Get Table Columns",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/tables/students/columns", "host": ["{{BASE_URL}}"], "path": ["api", "tables", "students", "columns"] },
            "description": "Returns detailed column metadata for a table: data types, nullability, defaults, primary key info."
          }
        },
        {
          "name": "Get Table Relationships",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/tables/students/relationships", "host": ["{{BASE_URL}}"], "path": ["api", "tables", "students", "relationships"] },
            "description": "Returns all FK relationships (incoming and outgoing) for a table."
          }
        },
        {
          "name": "Preview Table Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/tables/students/preview?limit=10",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tables", "students", "preview"],
              "query": [{ "key": "limit", "value": "10" }]
            },
            "description": "Returns first N rows from a table (max 100) plus an estimated total row count."
          }
        }
      ]
    },
    {
      "name": "Templates",
      "item": [
        {
          "name": "List All Templates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/templates?page=1&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "templates"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Paginated list of all generated templates."
          }
        },
        {
          "name": "Generate Template (Single Table)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.templateId) {",
                  "    pm.collectionVariables.set('TEMPLATE_ID', jsonData.templateId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tables\": [\"students\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{BASE_URL}}/api/templates", "host": ["{{BASE_URL}}"], "path": ["api", "templates"] },
            "description": "Introspects PostgreSQL schema for the given tables. Join keys appear ONCE (unprefixed) at the start of the header row."
          }
        },
        {
          "name": "Generate Template (Multi-Table)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.templateId) {",
                  "    pm.collectionVariables.set('TEMPLATE_ID', jsonData.templateId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tables\": [\"students\", \"student_users\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{BASE_URL}}/api/templates", "host": ["{{BASE_URL}}"], "path": ["api", "templates"] },
            "description": "Multi-table template. Shared columns (e.g. student_id) appear once at the beginning."
          }
        },
        {
          "name": "Get Template by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/templates/{{TEMPLATE_ID}}", "host": ["{{BASE_URL}}"], "path": ["api", "templates", "{{TEMPLATE_ID}}"] },
            "description": "Returns full template metadata including headers, headerMap, and columnsByTable."
          }
        },
        {
          "name": "Download Template (.xlsx)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/templates/{{TEMPLATE_ID}}/download", "host": ["{{BASE_URL}}"], "path": ["api", "templates", "{{TEMPLATE_ID}}", "download"] },
            "description": "Downloads the Excel template file. Use 'Send and Download' in Postman."
          }
        },
        {
          "name": "Delete Template",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/templates/{{TEMPLATE_ID}}", "host": ["{{BASE_URL}}"], "path": ["api", "templates", "{{TEMPLATE_ID}}"] },
            "description": "Deletes a template and its MinIO artifact."
          }
        }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
          "name": "List All Uploads",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/uploads?page=1&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "uploads"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Paginated list of all uploads. Filter by ?status=completed or ?templateId=xxx"
          }
        },
        {
          "name": "List Uploads by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/uploads?status=completed",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "uploads"],
              "query": [{ "key": "status", "value": "completed" }]
            }
          }
        },
        {
          "name": "Upload Excel File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.uploadId) {",
                  "    pm.collectionVariables.set('UPLOAD_ID', jsonData.uploadId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select a .xlsx file generated from a PDIE template"
                }
              ]
            },
            "url": { "raw": "{{BASE_URL}}/api/uploads", "host": ["{{BASE_URL}}"], "path": ["api", "uploads"] },
            "description": "Upload a filled Excel template. Sync (<5000 rows) returns 200, async returns 202. Data is inserted into ALL tables defined in the template."
          }
        },
        {
          "name": "Get Upload Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/uploads/{{UPLOAD_ID}}", "host": ["{{BASE_URL}}"], "path": ["api", "uploads", "{{UPLOAD_ID}}"] },
            "description": "Returns upload status, row count, processing mode, and timestamps."
          }
        },
        {
          "name": "Get Upload Processing Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/uploads/{{UPLOAD_ID}}/logs?page=1&limit=50",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "uploads", "{{UPLOAD_ID}}", "logs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            },
            "description": "Processing log trail: upload received → validation → ingest stages."
          }
        },
        {
          "name": "Get Upload Validation Errors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/uploads/{{UPLOAD_ID}}/errors?page=1&limit=50",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "uploads", "{{UPLOAD_ID}}", "errors"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            },
            "description": "Row-level validation errors with the row number, error messages, and original payload."
          }
        }
      ]
    }
  ]
}
