# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Comma-separated allowed frontend origins (production only)
ALLOWED_ORIGINS=http://emailservice-frontend:3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=placement_erp          # notifications database
MONGO_IMPORTER_DB=db_importer        # import logs + temp passwords database

# ── PostgreSQL (importer features) ───────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_CLIENT_ID=placement-erp-backend
KAFKA_BROKERS=redpanda:9092
KAFKA_PENDING_TOPIC=job.notification.pending
KAFKA_SEND_TOPIC=job.notification.send
KAFKA_CONSUMER_GROUP=placement-approval-group
KAFKA_EMAIL_CONSUMER_GROUP=placement-email-consumer-group

# ── Email consumer ────────────────────────────────────────────────────────────
EMAIL_CONSUMER_ENABLED=true
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
ZEPTOMAIL_TOKEN=Zoho-enczapikey...
FROM_EMAIL=noreply@example.com
FROM_NAME=Placement Cell

# ── Object Storage (MinIO / Cloudflare R2) ────────────────────────────────────
OBJECT_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
OBJECT_STORAGE_ACCESS_KEY=<access-key>
OBJECT_STORAGE_SECRET_KEY=<secret-key>
OBJECT_STORAGE_BUCKET=placement-erp-assets
OBJECT_STORAGE_USE_SSL=true
OBJECT_STORAGE_AUTO_CREATE_BUCKET=false
