PORT=4000

MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=placement_erp

REDIS_URL=redis://redis:6379

KAFKA_CLIENT_ID=placement-approval-service
KAFKA_BROKERS=redpanda:9092
KAFKA_CONSUMER_GROUP=placement-approval-group
KAFKA_PENDING_TOPIC=job.notification.pending
KAFKA_SEND_TOPIC=job.notification.send

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=email-bodies

# Excel upload/export feature
EXCEL_ADMIN_API_KEY=change-me-to-a-strong-secret
EXCEL_QUEUE_NAME=excel-queue
EXCEL_UPLOAD_DIR=                            # leave blank to use the default ./excel/uploads directory
EXCEL_MAX_UPLOAD_BYTES=5242880
EXCEL_MAX_ROWS=5000
EXCEL_UPLOAD_RATE_MAX=2
EXCEL_UPLOAD_RATE_WINDOW_MS=60000
EXCEL_JOB_RETENTION_DAYS=7
EXCEL_CLEANUP_INTERVAL_MS=3600000
EXCEL_FAILED_PREVIEW_LIMIT=5
EXCEL_DELETE_IMPORTED_DATA_ON_CLEANUP=false
